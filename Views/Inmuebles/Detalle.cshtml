@model PortalInmobiliario.Models.Inmueble
@{
    ViewData["Title"] = "Detalle";
    bool hayReservaActiva = (bool)(ViewBag.HayReservaActiva ?? false);
}

<h2>@Model.Titulo</h2>
<p><strong>Código:</strong> @Model.Codigo</p>
<p><strong>Ciudad:</strong> @Model.Ciudad</p>
<p><strong>Dirección:</strong> @Model.Direccion</p>
<p><strong>Tipo:</strong> @Model.Tipo</p>
<p><strong>Dormitorios:</strong> @Model.Dormitorios</p>
<p><strong>Baños:</strong> @Model.Banos</p>
<p><strong>Metros²:</strong> @Model.MetrosCuadrados</p>
<p><strong>Precio:</strong> @Model.Precio</p>

@if (!string.IsNullOrWhiteSpace(Model.Imagen))
{
    <img src="@Model.Imagen" alt="Imagen" class="img-fluid mb-3" />
}

@if (TempData["ok"] != null) { <div class="alert alert-success">@TempData["ok"]</div> }
@if (TempData["err"] != null) { <div class="alert alert-danger">@TempData["err"]</div> }

<hr />
@if (User.Identity?.IsAuthenticated ?? false)
{
    <!-- Reservar ahora (solo si no hay reserva activa) -->
    @if (!hayReservaActiva)
    {
        <form asp-controller="Reservas" asp-action="Reservar" method="post" class="mb-3 d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="inmuebleId" value="@Model.Id" />
            <button class="btn btn-primary">Reservar ahora (48h)</button>
        </form>
    }
    else
    {
        <div class="alert alert-warning">Este inmueble ya tiene una reserva activa.</div>
    }

    <!-- Agendar visita -->
    <h4 class="mt-4">Agendar visita</h4>
    <form asp-controller="Visitas" asp-action="Agendar" method="post" class="row g-2">
        @Html.AntiForgeryToken()
        <input type="hidden" name="inmuebleId" value="@Model.Id"/>
        <div class="col-12 col-md-4">
            <label class="form-label">Inicio</label>
            <input type="datetime-local" name="fechaInicio" class="form-control" required/>
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label">Fin</label>
            <input type="datetime-local" name="fechaFin" class="form-control" required/>
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label">Notas (opcional)</label>
            <input name="notas" class="form-control" />
        </div>
        <div class="col-12 mt-2">
            <button class="btn btn-outline-primary">Solicitar visita</button>
        </div>
    </form>
}
else
{
    <a href="/Identity/Account/Login" class="btn btn-warning">Inicia sesión para agendar o reservar</a>
}
